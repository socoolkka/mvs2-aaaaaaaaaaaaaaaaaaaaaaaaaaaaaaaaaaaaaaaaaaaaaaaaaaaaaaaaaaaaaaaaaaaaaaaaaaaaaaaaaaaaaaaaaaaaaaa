local function startWeaponESP()
    clearAllWeapon()
    local container=workspace:FindFirstChild("CharacterContainer")
    if container then
        for _,model in ipairs(container:GetChildren()) do if isMyCharacter(model) then monitorWeaponModel(model) end end
        table.insert(weaponConnections,container.ChildAdded:Connect(function(model) task.wait(1) if WeaponESP.Enabled and isMyCharacter(model) then monitorWeaponModel(model) end end))
    end
    for _,wm in ipairs(workspace:GetDescendants()) do if wm:IsA("WorldModel") then monitorWeaponModel(wm) end end
    table.insert(weaponConnections,workspace.DescendantAdded:Connect(function(obj) if WeaponESP.Enabled and obj:IsA("WorldModel") then monitorWeaponModel(obj) end end))
    for _,obj in ipairs(workspace:GetDescendants()) do if obj.Name=="ViewModelRig" then monitorViewModelRig(obj) end end
