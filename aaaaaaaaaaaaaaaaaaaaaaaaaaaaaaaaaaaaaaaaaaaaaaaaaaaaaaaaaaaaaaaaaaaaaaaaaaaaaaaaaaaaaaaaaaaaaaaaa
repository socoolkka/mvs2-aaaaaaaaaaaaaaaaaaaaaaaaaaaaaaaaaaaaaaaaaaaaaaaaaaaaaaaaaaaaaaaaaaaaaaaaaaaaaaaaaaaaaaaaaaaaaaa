local function GetESPColor(key,p)
    if ChamsMode.Enabled and p then return HasWallBetween(p.Character) and ChamsMode.ColorHidden or ChamsMode.ColorVisible end
    if ESP_CFG[key].Rainbow then return RainbowColor(0.35) end
    return ESP_CFG[key].Color
end

local function GetClosestPlayerInFOV()
    local closestPlayer,shortestDistance=nil,math.huge
    pcall(function()
        local view=Camera.ViewportSize if not view then return end local center=Vector2.new(view.X/2,view.Y/2)
        for _,p in ipairs(Players:GetPlayers()) do
            pcall(function()
                if p==LocalPlayer then return end if not IsEnemyAimbot(p) then return end if AimbotKillCheck and not IsAlive(p) then return end if not p.Character then return end
                local targetPart=p.Character:FindFirstChild(ResolvePart(AimbotTargetSelect)) if not targetPart then return end
                if AimbotWallCheck and HasWallBetween(p.Character) then return end
                local screenPos,onScreen=Camera:WorldToViewportPoint(targetPart.Position) if not onScreen then return end
                local distance=(Vector2.new(screenPos.X,screenPos.Y)-center).Magnitude
                if distance<AimbotFOV and distance<shortestDistance then closestPlayer=p shortestDistance=distance end
            end)
        end
    end)
    return closestPlayer
end

RunService.RenderStepped:Connect(function(dt)
    pcall(function()
        local view=Camera.ViewportSize
        FOVCircle.Color=RainbowColor(0.35) FOVFrame.Size=UDim2.fromOffset(AimbotFOV*2,AimbotFOV*2) FOVFrame.Visible=AimbotEnabled
