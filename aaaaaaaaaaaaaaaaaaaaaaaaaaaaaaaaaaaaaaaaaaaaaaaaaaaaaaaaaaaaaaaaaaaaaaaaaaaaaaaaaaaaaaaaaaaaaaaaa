local function CheckWallBetween(targetChar)
    if not targetChar then return true end
    local head=targetChar:FindFirstChild("Head") if not head then return true end
    local myChar=LocalPlayer.Character if not myChar then return true end
    local myHead=myChar:FindFirstChild("Head") if not myHead then return true end
    local origin=myHead.Position local target=head.Position local delta=target-origin local distance=delta.Magnitude
    if distance==0 then return true end
    local rp=RaycastParams.new() rp.FilterDescendantsInstances={myChar,targetChar} rp.FilterType=Enum.RaycastFilterType.Blacklist
    local r=workspace:Raycast(origin,delta.Unit*distance,rp) return r~=nil
end
local function HasWallBetween(targetChar) local ok,res=pcall(CheckWallBetween,targetChar) return ok and res or false end

local function UpdateChams(p)
    if p==LocalPlayer then return end
    if not ChamsMode.Enabled or not p.Character then
        if ChamsHighlights[p] then ChamsHighlights[p]:Destroy() ChamsHighlights[p]=nil end return
    end
    if not ChamsHighlights[p] or not ChamsHighlights[p].Parent then
        local h=Instance.new("Highlight") h.Name="HomoHubChams" h.FillTransparency=0.4 h.OutlineTransparency=0 h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop h.Parent=p.Character ChamsHighlights[p]=h
