local function createWeaponHighlight(obj)
    if weaponHighlights[obj] then return end
    local h=Instance.new("Highlight") h.Name="WeaponHighlight" h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    h.FillTransparency=WeaponESP.FillTransparency h.OutlineTransparency=WeaponESP.OutlineTransparency
    h.FillColor=WeaponESP.FillColor h.OutlineColor=WeaponESP.OutlineColor h.Adornee=obj h.Parent=obj weaponHighlights[obj]=h
end
local function registerWeaponObject(obj) if weaponRegistered[obj] then return end weaponRegistered[obj]=true createWeaponHighlight(obj) end
local function monitorWeaponItem(item)
    registerWeaponObject(item)
    for _,obj in ipairs(item:GetDescendants()) do if obj:IsA("BasePart") or obj:IsA("MeshPart") then registerWeaponObject(obj) end end
    table.insert(weaponConnections,item.DescendantAdded:Connect(function(obj) if WeaponESP.Enabled and (obj:IsA("BasePart") or obj:IsA("MeshPart")) then registerWeaponObject(obj) end end))
end
local function monitorWeaponModel(model)
    for _,obj in ipairs(model:GetDescendants()) do if validNames[obj.Name] then monitorWeaponItem(obj) end end
    table.insert(weaponConnections,model.DescendantAdded:Connect(function(obj) if WeaponESP.Enabled and validNames[obj.Name] then monitorWeaponItem(obj) end end))
end
local function isMyCharacter(model) return model.Name==DisplayName end
local function monitorViewModelRig(rig)
    local vm=rig:FindFirstChild("ViewModel") if vm then monitorWeaponModel(vm) end
