            local target=GetClosestPlayerInFOV()
            if target and target.Character then
                local targetPart=target.Character:FindFirstChild(ResolvePart(AimbotTargetSelect))
                if targetPart then Camera.CFrame=CFrame.new(Camera.CFrame.Position,targetPart.Position) end
            end
        end
        if WeaponESP.Enabled then
            weaponHue=(weaponHue+dt*0.25)%1 local rainbow=Color3.fromHSV(weaponHue,1,1)
            for _,h in pairs(weaponHighlights) do
                if h and h.Parent then
                    h.FillTransparency=WeaponESP.FillTransparency h.OutlineTransparency=WeaponESP.OutlineTransparency
                    if WeaponESP.Rainbow then h.FillColor=rainbow h.OutlineColor=rainbow else h.FillColor=WeaponESP.FillColor h.OutlineColor=WeaponESP.OutlineColor end
                end
            end
        end
        local centerPos=Vector2.new(view.X/2,view.Y/2)
        if VENOX_CROSSHAIR.Enabled then
            if VENOX_CROSSHAIR.Spin_Enabled then crosshairRotation=(crosshairRotation+dt*VENOX_CROSSHAIR.Spin_Speed)%(math.pi*2) end
            local extend=math.sin(tick()*VENOX_CROSSHAIR.Pulse_Speed)*VENOX_CROSSHAIR.Line_MaxExtend
            local chColor=VENOX_CROSSHAIR.Rainbow and Color3.fromHSV((tick()*0.15)%1,1,1) or VENOX_CROSSHAIR.Static_Color
            for i=1,#CrosshairLines do
                local angle=crosshairRotation+((math.pi*2)/VENOX_CROSSHAIR.Line_Count)*(i-1)
                local dir=Vector2.new(math.cos(angle),math.sin(angle))
                local from=centerPos+dir*VENOX_CROSSHAIR.Line_Gap local to=centerPos+dir*(VENOX_CROSSHAIR.Line_Gap+VENOX_CROSSHAIR.Line_Length+extend)
                local s=CrosshairStrokeLines[i] if s then s.From=from s.To=to s.Color=VENOX_CROSSHAIR.Stroke_Color s.Visible=VENOX_CROSSHAIR.Stroke_Enabled end
                local l=CrosshairLines[i] if l then l.From=from l.To=to l.Color=chColor l.Visible=true end
            end
            CrosshairText.Position=centerPos+VENOX_CROSSHAIR.Text_Offset CrosshairText.Color=chColor CrosshairText.Visible=VENOX_CROSSHAIR.Text_Enabled
        else
            for _,l in ipairs(CrosshairLines) do l.Visible=false end for _,l in ipairs(CrosshairStrokeLines) do l.Visible=false end CrosshairText.Visible=false
        end
        local myChar=LocalPlayer.Character local myHrp=myChar and myChar:FindFirstChild("HumanoidRootPart") local myAlive=myHrp~=nil
        for _,p in ipairs(Players:GetPlayers()) do
            if p==LocalPlayer then if ChamsHighlights[p] then ChamsHighlights[p]:Destroy() ChamsHighlights[p]=nil end if Tracers[p] then Tracers[p].Visible=false end continue end
            local showESP=not (ESP_CFG.TeamCheck and IsTeammate(p))
            if ChamsMode.Enabled and p.Character and showESP then UpdateChams(p)
            else if ChamsHighlights[p] then ChamsHighlights[p]:Destroy() ChamsHighlights[p]=nil end end
            if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
                if Tracers[p] then Tracers[p].Visible=false end if SkeletonLines[p] then for _,l in ipairs(SkeletonLines[p]) do l.Visible=false end end
                if Boxes[p] then for _,l in ipairs(Boxes[p]) do l.Visible=false end end if Distances[p] then Distances[p].Visible=false end if Names[p] then Names[p].Visible=false end continue
            end
            local char=p.Character local hrp=char.HumanoidRootPart local head=char:FindFirstChild("Head") if not head then continue end
            local rootPos,onScreen=Camera:WorldToViewportPoint(hrp.Position)
            if not onScreen then
                if Tracers[p] then Tracers[p].Visible=false end if SkeletonLines[p] then for _,l in ipairs(SkeletonLines[p]) do l.Visible=false end end
                if Boxes[p] then for _,l in ipairs(Boxes[p]) do l.Visible=false end end if Distances[p] then Distances[p].Visible=false end if Names[p] then Names[p].Visible=false end continue
            end
            if ESP_CFG.Tracer.Enabled and showESP and Tracers[p] then Tracers[p].Visible=true Tracers[p].Color=GetESPColor("Tracer",p) Tracers[p].From=Vector2.new(view.X/2,0) Tracers[p].To=Vector2.new(rootPos.X,rootPos.Y) elseif Tracers[p] then Tracers[p].Visible=false end
            if ESP_CFG.Skeleton.Enabled and showESP and SkeletonLines[p] then
                local skColor=GetESPColor("Skeleton",p)
                for i=1,#SkeletonPath-1 do local a=char:FindFirstChild(SkeletonPath[i]) local b=char:FindFirstChild(SkeletonPath[i+1]) local l=SkeletonLines[p][i] if a and b then local v1,o1=Camera:WorldToViewportPoint(a.Position) local v2,o2=Camera:WorldToViewportPoint(b.Position) if o1 and o2 then l.Visible=true l.Color=skColor l.From=Vector2.new(v1.X,v1.Y) l.To=Vector2.new(v2.X,v2.Y) else l.Visible=false end else l.Visible=false end end
            elseif SkeletonLines[p] then for _,l in ipairs(SkeletonLines[p]) do l.Visible=false end end
            if ESP_CFG.Box.Enabled and showESP and Boxes[p] then
                local boxColor=GetESPColor("Box",p)
                local headPos=Camera:WorldToViewportPoint(head.Position+Vector3.new(0,0.5,0)) local legPos=Camera:WorldToViewportPoint(hrp.Position-Vector3.new(0,2.8,0))
                local h=math.abs(headPos.Y-legPos.Y) local w=h*0.55 local x=rootPos.X-w/2 local y=headPos.Y local b=Boxes[p]
                for _,l in ipairs(b) do l.Visible=true l.Color=boxColor end
                b[1].From=Vector2.new(x,y) b[1].To=Vector2.new(x+w,y) b[2].From=Vector2.new(x,y+h) b[2].To=Vector2.new(x+w,y+h) b[3].From=Vector2.new(x,y) b[3].To=Vector2.new(x,y+h) b[4].From=Vector2.new(x+w,y) b[4].To=Vector2.new(x+w,y+h)
            elseif Boxes[p] then for _,l in ipairs(Boxes[p]) do l.Visible=false end end
