local KS_Connected = {}

local function KS_MonitorSound(sound)
    if not sound:IsA("Sound") then return end
    if KS_Connected[sound] then return end
    KS_Connected[sound] = true
    sound.Played:Connect(function()
        if not KS_CFG.Enabled then return end
        local currentId = tostring(sound.SoundId):match("%d+")
        if not currentId then return end
        if currentId == KS_CFG.TargetId then
            sound.Volume = 0
            local newSound = Instance.new("Sound")
            newSound.SoundId = "rbxassetid://" .. KS_CFG.ReplaceSoundId
            newSound.Volume = 1
            newSound.Parent = SS
            newSound:Play()
            newSound.Ended:Connect(function() newSound:Destroy() end)
        end
    end)
end

